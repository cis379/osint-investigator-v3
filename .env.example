# Copy to .env (gitignored) and fill in. Tools degrade gracefully without these.
# Free keys unless noted.

# Already-wired tools that now need keys (fix-first batch):
ETHERSCAN_API_KEY=          # free: https://etherscan.io/apis  (v2 endpoint; v1 sunset 2025-05)
ABUSE_CH_API_KEY=           # free: https://auth.abuse.ch/  (ThreatFox now requires Auth-Key)

# Tier-2 tools (added during HTTP wiring) — free keys:
ABUSEIPDB_API_KEY=          # https://www.abuseipdb.com/
VIRUSTOTAL_API_KEY=         # https://www.virustotal.com/
OTX_API_KEY=                # https://otx.alienvault.com/
NETLAS_API_KEY=             # https://netlas.io/
YOUTUBE_API_KEY=            # Google Cloud console
COMPANIES_HOUSE_API_KEY=    # https://developer.company-information.service.gov.uk/
GREYNOISE_API_KEY=          # optional; raises the free Community quota

# Paid / gated (Tier-4):
HIBP_API_KEY=               # ~$3.50/mo: https://haveibeenpwned.com/API/Key
